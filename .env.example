# ── Firebase ──────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Admin backdoor — NEVER hardcode, NEVER commit with values ─────────────────
# Firebase account with this email is silently routed to /admin on sign-in
VITE_ADMIN_EMAIL=

# ── Anthropic (server-side only — no VITE_ prefix) ───────────────────────────
# Add to Netlify environment variables, NOT to this file
ANTHROPIC_API_KEY=

# ── ElevenLabs — voice activates automatically when key is present ────────────
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=

# ── URLs ──────────────────────────────────────────────────────────────────────
# All locked-app upgrade links point here
VITE_LANDING_PAGE_URL=https://hearseedo.jp
# Used in welcome emails sent by Firebase Cloud Function
PLATFORM_URL=https://app.hearseedo.jp

# ── App iframe URLs — fill in as each app deploys ────────────────────────────
VITE_APP_URL_PHONICS=
VITE_APP_URL_EIKEN=
VITE_APP_URL_SPEAK=
VITE_APP_URL_WONDERCAMP=
VITE_APP_URL_FAMILY=
VITE_APP_URL_SIPSWITCH=
VITE_APP_URL_INNERKEY=

# ── Firebase Cloud Function env (set in Firebase, not Netlify) ────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
