rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public read-only meta (signup counter) ─────────────────────────────
    match /meta/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ── AI cache — public read (cache hits), server write only ─────────────
    match /aiCache/{hash} {
      allow read: if true;
      allow write: if false;
    }

    // ── Platform analytics — public read, server write only ────────────────
    // log-page-view writes via service account (bypasses these rules)
    match /analytics/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ── App Registry — public read, server write only ──────────────────────
    match /appRegistry/{appId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Referral links — public read (code lookup), owner write ───────────
    match /referralLinks/{code} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == resource.data.ownerUid;
    }

    // ── Referral stats — owner read only, server write ────────────────────
    match /referrals/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── User profiles — owner read/write, admin read-all ─────────────────
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || request.auth.token.email == "hearseedo.english@gmail.com");
      allow write: if request.auth != null && request.auth.uid == uid;

      match /chatUsage/{day} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /weeklyCheckin/{week} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /missions/{day} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /learningPath/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /familyMembers/{memberId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        match /learningPath/{doc} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }

      match /notifications/{notifId} {
        allow read, update: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.token.email == "hearseedo.english@gmail.com";
        allow delete: if false;
      }

      match /coachingCards/{date} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /careerReady/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /globalReady/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /speakReady/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Learner Intelligence profiles — owner read, server write ──────────
    // Server writes via /api/intelligence and /api/chat (using Firebase API key)
    // Clients can read their own profile for dashboard display
    match /learnerProfiles/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;

      // Interaction log — owner read only
      match /interactions/{interactionId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // Confidence history — owner read only
      match /confidenceHistory/{date} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // EIKEN placement/mock-test/achievement/Monkey-Party records — owner
      // read only, written server-side via eiken-progress.js (its
      // service-account REST token bypasses this write:false, same pattern
      // as the profile doc itself).
      match /eikenPlacementResults/{attemptId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
      match /eikenMockAttempts/{attemptId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
      match /eikenAchievements/{achievementId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
      match /monkeyPartySessions/{sessionId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // ── Support messages — user owns thread, admin reads all ─────────────
    match /support/{uid} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || request.auth.token.email == "hearseedo.english@gmail.com");

      match /messages/{msgId} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || request.auth.token.email == "hearseedo.english@gmail.com");
      }
    }

    // ── Workbook redemption log — user create only (no edit/delete), admin read ─
    match /workbookRedemptions/{docId} {
      allow read: if request.auth != null && request.auth.token.email == "hearseedo.english@gmail.com";
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Admin audit log — any auth'd user can append, only admin can read ─
    match /adminLogs/{logId} {
      allow read: if request.auth != null && request.auth.token.email == "hearseedo.english@gmail.com";
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Admin config (DPA statuses, compliance settings) — admin only ────
    match /adminConfig/{docId} {
      allow read, write: if request.auth != null && request.auth.token.email == "hearseedo.english@gmail.com";
    }

    // ── User feedback / pulse — any auth'd user can submit, only admin can read ─
    match /feedback/{docId} {
      allow read: if request.auth != null && request.auth.token.email == "hearseedo.english@gmail.com";
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Deny everything else ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
